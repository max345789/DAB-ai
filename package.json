{
  "name": "dab-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:gateway": "node ai-gateway/index.js",
    "dev:worker": "node ai-worker/index.js",
    "system:start": "./scripts/start-system.sh",
    "system:stop": "./scripts/stop-system.sh",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 delete ecosystem.config.js || true",
    "load:test:ai": "node scripts/load-test-ai.js",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "build:production": "npm run typecheck && npm run build",
    "smoke:prod": "./scripts/smoke-prod.sh",
    "smoke:prod:custom": "./scripts/smoke-prod.sh"
  },
  "dependencies": {
    "bullmq": "^5.70.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ioredis": "^5.10.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "pm2": "^6.0.14",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
