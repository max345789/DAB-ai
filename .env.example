# ═══════════════════════════════════════════════════════════════
#  DAB AI Platform – Environment Variables
#  Copy this file to .env.local (frontend) and server/.env (backend)
#  Never commit files containing real secrets to version control.
# ═══════════════════════════════════════════════════════════════

# ── Frontend (Next.js) ──────────────────────────────────────────
# Public prefix: accessible in browser bundles
# Point to your deployed backend API base URL
NEXT_PUBLIC_API_BASE=https://api.yourdomain.com/api

# Optional: Integration connect URLs (used for popup login flows on profile page)
NEXT_PUBLIC_WHATSAPP_CONNECT_URL=
NEXT_PUBLIC_META_CONNECT_URL=
NEXT_PUBLIC_GOOGLE_CONNECT_URL=
NEXT_PUBLIC_EMAIL_CONNECT_URL=
NEXT_PUBLIC_CALENDAR_CONNECT_URL=

# ── Backend – Server ────────────────────────────────────────────
PORT=5001
NODE_ENV=production

# ── Supabase ────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Authentication ──────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_minimum_32_chars_change_in_production
APP_PUBLIC_URL=https://app.yourdomain.com
PASSWORD_RESET_TTL_MINS=30

# ── AI Providers ────────────────────────────────────────────────
# At least one AI key is required. Anthropic Claude is preferred.
AI_PROVIDER=openai
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
DISABLE_CHAT_FALLBACK=false

# Local LLM (no API cost) via Ollama
# Install: brew install ollama && brew services start ollama
# Model: ollama pull llama3.2:3b
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b

# ── AI Cloud Architecture ───────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379
AI_GATEWAY_KEY=change_me_gateway_secret
AI_GATEWAY_URL=http://localhost:4100
AI_GATEWAY_ENABLED=true
AI_GATEWAY_PORT=4100
AI_RESULT_SECRET=change_me_worker_signature_secret
BACKEND_API_URL=http://localhost:5001/api
CLAUDE_WORKER_ENDPOINT=
CLAUDE_WORKER_KEY=change_me_claude_worker_secret
CLAUDE_WORKER_MODEL=sonnet
CLAUDE_WORKER_TIMEOUT_MS=120000
CLAUDE_WORKER_MOCK=false
AI_USER_HOURLY_LIMIT=20
AI_WORKER_POOL_SIZE=2
# In local development only, the code falls back to built-in dev secrets if
# these are omitted. Set real values for shared environments and production.

# ── Ad Platform Integrations ─────────────────────────────────────
META_ADS_TOKEN=your_meta_ads_access_token
META_AD_ACCOUNT_ID=act_your_account_id
GOOGLE_ADS_TOKEN=your_google_ads_api_token
GOOGLE_ADS_CUSTOMER_ID=your_customer_id

# ── Messaging Integrations ───────────────────────────────────────
WHATSAPP_API_KEY=your_whatsapp_cloud_api_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token

# ── Email / SMTP ─────────────────────────────────────────────────
EMAIL_SMTP_KEY=your_smtp_api_key_or_password
EMAIL_SMTP_HOST=smtp.yourmailprovider.com
EMAIL_SMTP_PORT=587
EMAIL_FROM_ADDRESS=noreply@yourdomain.com

# ── Calendar ─────────────────────────────────────────────────────
CALENDLY_API_KEY=your_calendly_api_key
# or Google Calendar:
GOOGLE_CALENDAR_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CALENDAR_CLIENT_SECRET=your_google_oauth_client_secret

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGIN=https://app.yourdomain.com
